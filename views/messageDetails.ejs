<html>
  <head>
    <link rel="stylesheet" href="/styles.css">
  </head>  
  <body>
    <%- include('header') %>
    <h2>Message Details</h2>
    <h3>Sent by:</h3>
    <p><%= message.user %></p>
    <h3>Message content:</h3>
    <p><%= message.text %></p>
    <h3>Time sent:</h3>
    <p><%= message.added %></p>
    <h3>Message ID:</h3>
    <p><%= message.id %></p>
  </body>
</html>